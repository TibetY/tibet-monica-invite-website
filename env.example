# Copy this file to .env and fill in real values.
# Set these in Netlify UI → Site Settings → Environment Variables.

# Supabase project URL and anon key (safe to be client-side; Supabase anon key is public by design)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# Guest list password — NO VITE_ prefix so Vite does NOT bundle this into the JS.
# Used only by the server-side Netlify Function at netlify/functions/verify-password.js
GUESTLIST_PASSWORD=your_password_here
